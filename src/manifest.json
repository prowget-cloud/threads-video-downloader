{
  "manifest_version": 3,
  "name": "Threads Video Downloader",
  "version": "1.0.0",
  "description": "Download video Threads dengan satu klik.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["downloads"],
  "content_scripts": [
    {
      "matches": ["https://www.threads.net/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}